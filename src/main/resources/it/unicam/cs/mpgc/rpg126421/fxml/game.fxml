<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="it.unicam.cs.mpgc.rpg126421.controller.GameController"
            style="-fx-background-color: #0a0a0a;">

    <!-- HUD superiore -->
    <top>
        <HBox spacing="24" alignment="CENTER_LEFT"
              style="-fx-background-color: #111111; -fx-padding: 12 20;
                     -fx-border-color: #f0c040; -fx-border-width: 0 0 1 0;">
            <Label fx:id="episodeTitleLabel"
                   style="-fx-text-fill: #f0c040; -fx-font-family: 'Courier New';
                          -fx-font-weight: bold; -fx-font-size: 14px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="captainNameLabel"
                   style="-fx-text-fill: #aaaaaa; -fx-font-family: 'Courier New';"/>
            <Label fx:id="woolongLabel"
                   style="-fx-text-fill: #f0c040; -fx-font-family: 'Courier New';
                          -fx-font-weight: bold;"/>
            <Label fx:id="moraleLabel"
                   style="-fx-text-fill: #88cc88; -fx-font-family: 'Courier New';"/>
        </HBox>
    </top>

    <!-- Testo narrativo -->
    <center>
        <TextArea fx:id="narrativeArea" editable="false" wrapText="true"
                  style="-fx-background-color: #0a0a0a; -fx-text-fill: #dddddd;
                         -fx-font-family: 'Courier New'; -fx-font-size: 14px;
                         -fx-border-width: 0; -fx-padding: 24;"
                  BorderPane.alignment="CENTER"/>
    </center>

    <!-- Scelte -->
    <bottom>
        <VBox fx:id="choicesBox" spacing="8"
              style="-fx-background-color: #111111; -fx-padding: 16;
                     -fx-border-color: #f0c040; -fx-border-width: 1 0 0 0;">
        </VBox>
    </bottom>
</BorderPane>