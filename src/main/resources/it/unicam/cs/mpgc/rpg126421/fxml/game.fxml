<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.text.Font?>
<?import java.net.URL?>
<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="it.unicam.cs.mpgc.rpg126421.controller.GameController"
           prefWidth="1024" prefHeight="768"
           style="-fx-background-color: #000000;">


<stylesheets>
        <URL value="@/it/unicam/cs/mpgc/rpg126421/css/bebop.css"/>
    </stylesheets>

    <!-- Sfondo episodio -->
    <ImageView fx:id="backgroundImage"
               fitWidth="1024" fitHeight="768"
               preserveRatio="false"
               mouseTransparent="true"/>

    <!-- Overlay scuro su sfondo -->
    <Pane mouseTransparent="true"
          style="-fx-background-color: rgba(2,4,2,0.45);"/>

    <!-- Scanlines -->
    <Pane styleClass="scanline-overlay" mouseTransparent="true"/>

    <!-- Layout principale -->
    <BorderPane style="-fx-background-color: transparent;">

        <!-- HUD superiore -->
        <top>
            <HBox spacing="30" alignment="CENTER_LEFT"
                  style="-fx-background-color: rgba(5,10,5,0.92);
                         -fx-padding: 15 25;
                         -fx-border-color: #00FF41;
                         -fx-border-width: 0 0 2 0;">

                <Label fx:id="episodeTitleLabel"
                       style="-fx-text-fill: #00FF41;">
                    <font><Font name="Impact" size="20.0"/></font>
                    <effect>
                        <DropShadow radius="10.0" spread="0.2">
                            <color><Color red="0.0" green="1.0" blue="0.2" opacity="0.6"/></color>
                        </DropShadow>
                    </effect>
                </Label>

                <Region HBox.hgrow="ALWAYS"/>

                <Label fx:id="captainNameLabel"
                       style="-fx-text-fill: #00FF41; -fx-font-family: 'Courier New';
                              -fx-font-size: 15px; -fx-font-weight: bold;"/>

                <Label fx:id="woolongLabel"
                       style="-fx-text-fill: #f0c040; -fx-font-family: 'Courier New';
                              -fx-font-weight: bold; -fx-font-size: 18px;"/>

                <Label fx:id="moraleLabel"
                       style="-fx-text-fill: #00BB33; -fx-font-family: 'Courier New';
                              -fx-font-size: 15px;"/>
            </HBox>
        </top>

        <!-- Centro: testo + facecard -->
        <center>
            <HBox spacing="30" alignment="CENTER" style="-fx-padding: 30 40;">

                <StackPane HBox.hgrow="ALWAYS"
                           styleClass="terminal-box"
                           alignment="TOP_LEFT"
                           maxWidth="650"
                           maxHeight="340"
                           style="-fx-background-color: rgba(2, 6, 2, 0.65);
                                  -fx-border-color: #00FF41;
                                  -fx-border-width: 1;
                                  -fx-background-radius: 4;
                                  -fx-border-radius: 4;
                                  -fx-effect: dropshadow(three-pass-box, rgba(0,255,65,0.12), 8, 0, 0, 0);">

                    <TextArea fx:id="narrativeArea"
                              editable="false"
                              wrapText="true"
                              style="-fx-control-inner-background: transparent;
                                     -fx-background-color: transparent;
                                     -fx-text-fill: #00FF41;
                                     -fx-font-family: 'Courier New';
                                     -fx-font-size: 18px; -fx-padding: 20;"/>
                </StackPane>

                <VBox fx:id="characterPanel"
                      alignment="CENTER"
                      prefWidth="280"
                      style="-fx-padding: 0;
                             -fx-background-color: transparent;">
                    <ImageView fx:id="characterImage"
                               fitWidth="240" fitHeight="320"
                               preserveRatio="true"
                               style="-fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.6), 12, 0, 0, 0);"/>
                </VBox>
            </HBox>
        </center>

        <!-- Scelte -->
        <bottom>
            <VBox fx:id="choicesContainer"
                  alignment="CENTER"
                  spacing="8"
                  style="-fx-background-color: rgba(2, 4, 2, 0.75);
                         -fx-padding: 12 25;
                         -fx-border-color: #00FF41;
                         -fx-border-width: 1 0 0 0;">

                <HBox fx:id="choicesBox"
                      spacing="15"
                      alignment="CENTER"
                      style="-fx-background-color: transparent;"/>
            </VBox>
        </bottom>
    </BorderPane>
</StackPane>
