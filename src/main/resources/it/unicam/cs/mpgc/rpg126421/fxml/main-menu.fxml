<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.*?>

<?import java.net.URL?>
<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="it.unicam.cs.mpgc.rpg126421.controller.MainMenuController"
           prefWidth="1024" prefHeight="768"
           style="-fx-background-color: #010a01;">

    <stylesheets>
        <URL value="@/it/unicam/cs/mpgc/rpg126421/css/bebop.css"/>
    </stylesheets>

    <!-- Sfondo placeholder episodio -->
    <Pane style="-fx-background-color: #010a01;"/>

    <!-- Scanline overlay -->
    <Pane styleClass="scanline-overlay" mouseTransparent="true"/>

    <!-- Contenuto centrato -->
    <VBox alignment="CENTER" spacing="16">

        <Label fx:id="titleLabel"
               text="COWBOY BebOOP"
               styleClass="label-title"
               style="-fx-font-size: 52px;"/>

        <Label text="— 3, 2, 1... LET'S JAM —"
               styleClass="label-subtitle"/>

        <VBox spacing="12" alignment="CENTER"
              style="-fx-padding: 48 0 0 0;">

            <Button fx:id="newGameButton"
                    text="[ NUOVA PARTITA ]"
                    styleClass="btn-primary"
                    onAction="#onNewGame"/>

            <Button fx:id="quitButton"
                    text="[ ESCI ]"
                    styleClass="btn-secondary"
                    onAction="#onQuit"/>
        </VBox>

        <Label text="v0.1 — ISSP BOUNTY NETWORK"
               styleClass="label-subtitle"
               style="-fx-font-size: 10px; -fx-padding: 32 0 0 0;"/>
    </VBox>
</StackPane>