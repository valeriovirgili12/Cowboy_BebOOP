<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="it.unicam.cs.mpgc.rpg126421.controller.GameOverController"
      alignment="CENTER" spacing="20"
      style="-fx-background-color: #0a0a0a; -fx-padding: 60;">
    <Label fx:id="titleLabel"
           style="-fx-font-size: 48px; -fx-font-weight: bold;
                  -fx-text-fill: #ff4444; -fx-font-family: 'Courier New';"/>
    <TextArea fx:id="reasonArea" editable="false" wrapText="true"
              prefHeight="150" maxWidth="600"
              style="-fx-background-color: #111111; -fx-text-fill: #dddddd;
                     -fx-font-family: 'Courier New'; -fx-border-color: #333333;"/>
    <Label fx:id="woolongLabel"
           style="-fx-text-fill: #f0c040; -fx-font-family: 'Courier New';"/>
    <Button text="RICOMINCIA" onAction="#onRestart"
            style="-fx-background-color: #ff4444; -fx-text-fill: #ffffff;
                   -fx-font-family: 'Courier New'; -fx-font-weight: bold;
                   -fx-padding: 12 40; -fx-cursor: hand;"/>
</VBox>