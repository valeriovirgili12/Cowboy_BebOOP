<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>
<?import java.net.URL?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="it.unicam.cs.mpgc.rpg126421.controller.GameOverController"
      alignment="CENTER" spacing="30"
      style="-fx-background-color: #020402; -fx-padding: 60;">

    <stylesheets>
        <URL value="@/it/unicam/cs/mpgc/rpg126421/css/bebop.css"/>
    </stylesheets>

    <Label fx:id="titleLabel"
           style="-fx-font-size: 56px; -fx-font-family: 'Impact';
                  -fx-text-fill: #FF3333; -fx-effect: dropshadow(three-pass-box, rgba(255,51,51,0.4), 15, 0, 0, 0);"/>

    <TextArea fx:id="reasonArea" editable="false" wrapText="true"
              prefHeight="180" maxWidth="650"
              style="-fx-background-color: transparent; -fx-background: #020402;
                     -fx-viewport-background: #020402; -fx-border-color: transparent;
                     -fx-border-width: 0; -fx-background-insets: 0; -fx-box-border: transparent;
                     -fx-text-fill: #00FF41; -fx-font-family: 'Courier New'; -fx-font-size: 18px;"/>

    <Label fx:id="woolongLabel"
           style="-fx-text-fill: #f0c040; -fx-font-family: 'Courier New';
                  -fx-font-weight: bold; -fx-font-size: 18px;"/>

    <Button text="[ RICOMINCIA LA CACCIA ]"
            onAction="#onRestart"
            styleClass="button"
            style="-fx-text-fill: #FF3333; -fx-border-color: #FF3333; -fx-font-family: 'Impact'; -fx-font-size: 18px;"/>
</VBox>
