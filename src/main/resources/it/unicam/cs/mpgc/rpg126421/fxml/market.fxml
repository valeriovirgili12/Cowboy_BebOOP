<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="it.unicam.cs.mpgc.rpg126421.controller.MarketController"
            style="-fx-background-color: #0a0a0a;">
    <top>
        <HBox spacing="24" alignment="CENTER_LEFT"
              style="-fx-background-color: #111111; -fx-padding: 12 20;
                     -fx-border-color: #f0c040; -fx-border-width: 0 0 1 0;">
            <Label text="MERCATO NERO"
                   style="-fx-text-fill: #f0c040; -fx-font-family: 'Courier New';
                          -fx-font-weight: bold; -fx-font-size: 16px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="woolongLabel"
                   style="-fx-text-fill: #f0c040; -fx-font-family: 'Courier New';
                          -fx-font-weight: bold;"/>
        </HBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: #0a0a0a;">
            <VBox fx:id="itemsBox" spacing="12"
                  style="-fx-padding: 20;"/>
        </ScrollPane>
    </center>
    <bottom>
        <VBox style="-fx-background-color: #111111; -fx-padding: 12 20;
                     -fx-border-color: #f0c040; -fx-border-width: 1 0 0 0;">
            <Label fx:id="messageLabel" text=""
                   style="-fx-text-fill: #aaaaaa; -fx-font-family: 'Courier New';"/>
            <Button text="LASCIA LA STAZIONE →" onAction="#onLeave"
                    style="-fx-background-color: #f0c040; -fx-text-fill: #0a0a0a;
                           -fx-font-family: 'Courier New'; -fx-font-weight: bold;
                           -fx-padding: 10 24; -fx-cursor: hand;"/>
        </VBox>
    </bottom>
</BorderPane>