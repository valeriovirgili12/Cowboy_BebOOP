<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>
<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="it.unicam.cs.mpgc.rpg126421.controller.EndingController"
           prefWidth="1024" prefHeight="768"
           styleClass="root-pane">

    <stylesheets>
        <URL value="@/it/unicam/cs/mpgc/rpg126421/css/bebop.css"/>
    </stylesheets>

    <Pane style="-fx-background-color: #020402;"/>
    <Pane styleClass="scanline-overlay" mouseTransparent="true"/>

    <VBox spacing="16" style="-fx-padding: 40;">

        <!-- Titolo -->
        <Label fx:id="endingTitleLabel"
               styleClass="label-title"
               text="MISSIONE COMPLETATA"/>

        <!-- Stats HUD -->
        <HBox spacing="40" alignment="CENTER_LEFT"
              styleClass="hud-bar">
            <Label fx:id="finalWoolongLabel"
                   styleClass="label-woolong" text="WOOLONG: 0"/>
            <Label fx:id="finalMoraleLabel"
                   styleClass="label-hud" text="MORALE: 0"/>
        </HBox>

        <!-- Due colonne -->
        <HBox spacing="20" VBox.vgrow="ALWAYS">

            <!-- Sinistra — narrazione finale -->
            <VBox spacing="10" HBox.hgrow="ALWAYS">
                <Label text="— RAPPORTO FINALE —"
                       styleClass="label-subtitle"/>
                <TextArea fx:id="endingSummaryArea"
                          editable="false" wrapText="true"
                          prefHeight="440"
                          styleClass="narrative-area"
                          style="-fx-border-color: #004d14;
                                 -fx-border-width: 1;"
                          VBox.vgrow="ALWAYS"/>
            </VBox>

            <!-- Destra — registro scelte -->
            <VBox spacing="10" HBox.hgrow="ALWAYS">
                <Label text="— REGISTRO SCELTE —"
                       styleClass="label-subtitle"/>
                <TextArea fx:id="logArea"
                          editable="false" wrapText="true"
                          prefHeight="440"
                          styleClass="narrative-area"
                          style="-fx-border-color: #004d14;
                                 -fx-border-width: 1;"
                          VBox.vgrow="ALWAYS"/>
            </VBox>
        </HBox>

        <!-- Bottoni -->
        <HBox alignment="CENTER" spacing="20">
            <Button text="[ GIOCA ANCORA ]"
                    onAction="#onRestart"
                    styleClass="btn-primary"/>
        </HBox>

        <Label text="See you space cowboy..."
               styleClass="label-subtitle"
               style="-fx-padding: 4 0 0 0;"/>
    </VBox>
</StackPane>
