<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="it.unicam.cs.mpgc.rpg126421.controller.EndingController"
      alignment="CENTER" spacing="20"
      style="-fx-background-color: #0a0a0a; -fx-padding: 60;">

    <Label fx:id="endingTitleLabel"
           style="-fx-font-size: 32px; -fx-font-weight: bold;
                  -fx-text-fill: #f0c040; -fx-font-family: 'Courier New';"/>

    <TextArea fx:id="endingSummaryArea" editable="false" wrapText="true"
              prefHeight="200" maxWidth="600"
              style="-fx-background-color: #111111; -fx-text-fill: #dddddd;
                     -fx-font-family: 'Courier New'; -fx-font-size: 13px;
                     -fx-border-color: #333333; -fx-border-width: 1;"/>

    <HBox spacing="24" alignment="CENTER">
        <Label fx:id="finalWoolongLabel"
               style="-fx-text-fill: #f0c040; -fx-font-family: 'Courier New';
                      -fx-font-size: 14px;"/>
        <Label fx:id="finalMoraleLabel"
               style="-fx-text-fill: #88cc88; -fx-font-family: 'Courier New';
                      -fx-font-size: 14px;"/>
    </HBox>

    <Button fx:id="restartButton" text="GIOCA ANCORA" onAction="#onRestart"
            style="-fx-background-color: #f0c040; -fx-text-fill: #0a0a0a;
                   -fx-font-family: 'Courier New'; -fx-font-weight: bold;
                   -fx-padding: 12 40; -fx-cursor: hand;"/>
</VBox>